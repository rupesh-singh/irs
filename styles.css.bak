/* 
   IRS — Interview Revision Service  Premium Design System
   Typography: Inter  Color: Deep-navy / Slate / Electric-indigo accents
    */

/*  Google Font  */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap');

/*  Design Tokens (Dark — default)  */
:root {
  /* Palette */
  --bg:          #08090d;
  --bg-alt:      #10121a;
  --bg-glass:    rgba(16, 18, 26, .72);
  --bg-elevated: #161925;
  --surface:     #1a1d2e;
  --text:        #eaecf5;
  --text-dim:    #7c819a;
  --text-muted:  #4e5269;
  --accent:      #6366f1;
  --accent-hover:#818cf8;
  --accent-glow: rgba(99,102,241,.25);
  --accent2:     #a78bfa;
  --accent2-glow:rgba(167,139,250,.18);
  --border:      rgba(255,255,255,.06);
  --border-hover:rgba(255,255,255,.12);
  --danger:      #f87171;
  --success:     #34d399;
  --warn:        #fbbf24;
  --code-bg:     #0f1017;
  --ring:        rgba(99,102,241,.45);

  /* Radii */
  --r-sm: 8px;
  --r-md: 14px;
  --r-lg: 20px;
  --r-xl: 28px;
  --r-full: 999px;

  /* Motion */
  --ease:   cubic-bezier(.4,.0,.2,1);
  --spring: cubic-bezier(.34,1.56,.64,1);
  --dur:    .28s;
  --dur-lg: .45s;
  --transition: .3s cubic-bezier(.4,.0,.2,1);

  /* Type scale */
  --font:      'Inter', system-ui, -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
  --fs-xs:  .7rem;
  --fs-sm:  .8rem;
  --fs-base:.9rem;
  --fs-md:  1rem;
  --fs-lg:  1.15rem;
  --fs-xl:  1.35rem;
  --fs-2xl: 1.75rem;
  --fs-3xl: clamp(2rem, 5vw, 2.8rem);

  /* Shadows */
  --shadow-sm: 0 1px 3px rgba(0,0,0,.4);
  --shadow-md: 0 8px 32px rgba(0,0,0,.45);
  --shadow-lg: 0 20px 60px rgba(0,0,0,.55);
  --shadow-glow: 0 0 40px var(--accent-glow), 0 0 80px rgba(99,102,241,.08);
  --shadow-elev: 0 4px 16px rgba(0,0,0,.35), 0 12px 40px rgba(0,0,0,.25);

  /* Layout */
  --nav-h: 64px;
  --max-w: 1100px;
  --content-pad: clamp(1rem, 4vw, 2.5rem);
  --radius: 14px;
  --ring-alpha: rgba(99,102,241,.35);
}

/*  Light theme  */
html.light {
  --bg:          #f8f9fc;
  --bg-alt:      #ffffff;
  --bg-glass:    rgba(255,255,255,.78);
  --bg-elevated: #ffffff;
  --surface:     #f0f1f5;
  --text:        #0f172a;
  --text-dim:    #64748b;
  --text-muted:  #94a3b8;
  --accent:      #4f46e5;
  --accent-hover:#6366f1;
  --accent-glow: rgba(79,70,229,.18);
  --accent2:     #7c3aed;
  --accent2-glow:rgba(124,58,237,.12);
  --border:      rgba(0,0,0,.06);
  --border-hover:rgba(0,0,0,.12);
  --code-bg:     #f1f5f9;
  --ring:        rgba(79,70,229,.35);
  --ring-alpha:  rgba(79,70,229,.28);
  --shadow-sm:   0 1px 3px rgba(0,0,0,.06);
  --shadow-md:   0 8px 32px rgba(0,0,0,.08);
  --shadow-lg:   0 20px 60px rgba(0,0,0,.1);
  --shadow-glow: 0 0 40px rgba(79,70,229,.1), 0 0 80px rgba(79,70,229,.04);
  --shadow-elev: 0 4px 16px rgba(0,0,0,.05), 0 12px 40px rgba(0,0,0,.04);
}

/*  Reset & Base  */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  scroll-behavior: smooth;
  -webkit-text-size-adjust: 100%;
}

body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  line-height: 1.6;
  letter-spacing: -.01em;
  overflow-x: hidden;
}

/* Ambient background mesh */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: -1;
  background:
    radial-gradient(ellipse 80% 60% at 20% 10%, var(--accent-glow), transparent),
    radial-gradient(ellipse 60% 50% at 80% 80%, var(--accent2-glow), transparent);
  opacity: .6;
  pointer-events: none;
}

.app-root { flex: 1; display: flex; flex-direction: column; }

main#main {
  width: 100%;
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 1.5rem var(--content-pad) 4rem;
  outline: none;
}

::selection { background: var(--accent); color: #fff; }

/*  Utility  */
.sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); border:0; }
.fade { animation: fadeUp var(--dur-lg) var(--ease) both; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: none; }
}
/* Legacy compat alias */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: none; }
}
.empty { text-align: center; color: var(--text-dim); margin-top: 3rem; font-size: var(--fs-sm); }

/* 
   HEADER — Frosted glass navbar
    */
header.app-header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0 var(--content-pad);
  height: var(--nav-h);
  background: var(--bg-glass);
  border-bottom: 1px solid var(--border);
  backdrop-filter: saturate(1.4) blur(20px);
  -webkit-backdrop-filter: saturate(1.4) blur(20px);
  transition: background var(--dur) var(--ease), border-color var(--dur) var(--ease);
  flex-shrink: 0;
  overflow: hidden;
  min-height: 0;
}
header.app-header h1 { display: none; }
header.app-header .inline-group { flex-shrink: 0; }

.header-left { display:flex; align-items:center; gap:.85rem; flex:1 1 auto; min-width:0; }
.header-right { margin-left:auto; display:flex; align-items:center; gap:.5rem; }

.brand-block {
  display:flex;
  align-items:center;
  gap:.7rem;
  min-width:0;
  cursor: default;
}

.logo-pill {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font);
  font-weight: 800;
  font-size: var(--fs-sm);
  letter-spacing: .5px;
  color: #fff;
  box-shadow: 0 4px 16px var(--accent-glow);
  flex-shrink: 0;
  transition: transform var(--dur) var(--spring);
}
.logo-pill:hover { transform: scale(1.06) rotate(-2deg); }

.brand-copy { display:flex; flex-direction:column; gap:0; min-width:0; }
.brand-title { font-size: var(--fs-base); font-weight: 700; letter-spacing: -.02em; line-height: 1.2; }
.brand-tagline { font-size: var(--fs-xs); font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: .15em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/*  Buttons  */
header.app-header button, .pill-btn {
  background: var(--accent);
  color: #fff;
  border: none;
  padding: .5rem 1rem;
  font-size: var(--fs-sm);
  font-weight: 600;
  font-family: var(--font);
  border-radius: var(--r-full);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  transition: all var(--dur) var(--ease);
  position: relative;
  overflow: hidden;
  white-space: nowrap;
  box-shadow: 0 2px 10px rgba(0,0,0,.22);
}
header.app-header button:hover, .pill-btn:hover {
  background: var(--accent-hover);
  box-shadow: 0 4px 20px var(--accent-glow);
  transform: translateY(-1px);
}
header.app-header button:active, .pill-btn:active { transform: translateY(0) scale(.98); }
header.app-header button:focus-visible, .pill-btn:focus-visible { outline: none; box-shadow: 0 0 0 3px var(--ring); }

.pill-btn.ghost {
  background: transparent;
  color: var(--text-dim);
  border: 1px solid var(--border);
  box-shadow: none;
}
.pill-btn.ghost:hover {
  color: var(--text);
  background: var(--surface);
  border-color: var(--border-hover);
  box-shadow: none;
  transform: none;
}
.pill-btn.ghost:focus-visible { box-shadow: 0 0 0 3px var(--ring); }

.back-btn { font-size: var(--fs-sm); border-color: rgba(255,255,255,.2); background: rgba(255,255,255,.05); }
.header-link { background: transparent; border-color: rgba(255,255,255,.25); }
.theme-btn { min-width: 0; }

/*  Skip link a11y  */
.skip-link { position:absolute; left:-9999px; top:0; background:var(--accent); color:#fff; padding:.5rem .75rem; border-radius: var(--r-sm); text-decoration:none; z-index:999; }
.skip-link:focus { left:.75rem; top:.5rem; box-shadow:0 0 0 3px var(--ring); }


/* 
   HOME — Hero landing with glassmorphic card
    */
.home { min-height: calc(100vh - var(--nav-h) - 6rem); display: flex; align-items: flex-start; justify-content: center; padding-top: clamp(1.5rem, 6vh, 4rem); }

.home-inner {
  width: 100%;
  max-width: 960px;
  text-align: center;
  padding: clamp(2rem, 5vw, 3.5rem) clamp(1.5rem, 5vw, 3rem);
  border-radius: var(--r-xl);
  background: var(--bg-glass);
  border: 1px solid var(--border);
  backdrop-filter: saturate(1.3) blur(24px);
  -webkit-backdrop-filter: saturate(1.3) blur(24px);
  box-shadow: var(--shadow-lg), var(--shadow-glow);
  position: relative;
  overflow: hidden;
}
/* Decorative orb behind card */
.home-inner::before {
  content: '';
  position: absolute;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, var(--accent-glow), transparent 70%);
  top: -100px;
  right: -80px;
  pointer-events: none;
  opacity: .5;
}
.home-inner::after {
  content: '';
  position: absolute;
  width: 200px;
  height: 200px;
  border-radius: 50%;
  background: radial-gradient(circle, var(--accent2-glow), transparent 70%);
  bottom: -60px;
  left: -40px;
  pointer-events: none;
  opacity: .6;
}

.home-title {
  font-size: var(--fs-3xl);
  font-weight: 800;
  letter-spacing: -.03em;
  line-height: 1.15;
  margin: 0 0 .4rem;
  background: linear-gradient(135deg, var(--text) 30%, var(--accent) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  position: relative;
  z-index: 1;
}

.home-sub {
  color: var(--text-dim);
  margin: 0 0 1.75rem;
  font-size: var(--fs-md);
  font-weight: 400;
  position: relative;
  z-index: 1;
}

/* Search bar */
.home-search { position: relative; max-width: 560px; margin: 0 auto 2rem; z-index: 2; }

.home-search input {
  width: 100%;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: .85rem 1.15rem .85rem 1rem;
  color: var(--text);
  font-size: var(--fs-base);
  font-family: var(--font);
  outline: none;
  transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
}
.home-search input::placeholder { color: var(--text-muted); }
.home-search input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--ring), 0 8px 24px rgba(0,0,0,.15);
}

.home-results {
  position: absolute;
  left: 0; right: 0;
  top: calc(100% + 8px);
  background: var(--bg-elevated);
  border: 1px solid var(--border-hover);
  border-radius: var(--r-md);
  max-height: 340px;
  overflow: auto;
  box-shadow: var(--shadow-md);
  text-align: left;
  z-index: 50;
}
.home-result {
  padding: .65rem .9rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: .6rem;
  cursor: pointer;
  transition: background var(--dur) var(--ease);
  border-bottom: 1px solid var(--border);
}
.home-result:first-child { border-top: none; }
.home-result:last-child { border-bottom: none; }
.home-result:hover, .home-result:focus-visible { background: var(--surface); outline: none; }
.hr-title { font-weight: 600; font-size: var(--fs-sm); }
.hr-type {
  font-size: var(--fs-xs);
  color: var(--text-muted);
  background: var(--surface);
  padding: .15rem .45rem;
  border-radius: var(--r-sm);
  font-weight: 500;
}

/*  Section grid — Bento-style cards  */
.section-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: .85rem;
  max-width: 680px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.section-card {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 1.25rem 1rem;
  text-align: center;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .45rem;
  transition: all var(--dur) var(--ease);
  position: relative;
  overflow: hidden;
  font-family: var(--font);
}
.section-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(135deg, var(--accent-glow), transparent);
  opacity: 0;
  transition: opacity var(--dur) var(--ease);
}
.section-card:hover::before { opacity: 1; }
.section-card:hover {
  transform: translateY(-3px);
  border-color: var(--accent);
  box-shadow: var(--shadow-md), 0 0 30px var(--accent-glow);
}
.section-card:active { transform: translateY(-1px) scale(.98); }
.section-card:focus-visible { outline: none; box-shadow: 0 0 0 3px var(--ring); }

.sc-icon {
  font-size: 1.8rem;
  line-height: 1;
  position: relative;
  z-index: 1;
  transition: transform var(--dur) var(--spring);
  flex: 0 0 auto;
}
.section-card:hover .sc-icon { transform: scale(1.15); }

.sc-title { font-weight: 700; position: relative; z-index: 1; }
.sc-sub {
  font-size: var(--fs-sm);
  font-weight: 600;
  color: var(--text-dim);
  position: relative;
  z-index: 1;
  transition: color var(--dur) var(--ease);
  flex: 1 1 auto;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.section-card:hover .sc-sub { color: var(--text); }

/* Game card special glow on home */
.game-card-home {
  border-color: rgba(99,102,241,.2);
  background: linear-gradient(135deg, rgba(99,102,241,.06), rgba(167,139,250,.04));
}
.game-card-home:hover { border-color:var(--accent); box-shadow:0 8px 24px var(--accent-glow); }


/* 
   MARKDOWN SECTIONS — List + Viewer
    */
.md-container { width:100%; max-width:900px; margin:0 auto; padding:1rem 0; }

.section-filter { max-width:900px; margin:.5rem auto 1.25rem; position: relative; padding: 0 1rem; }
.section-filter input {
  width: 100%;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: .7rem 1rem;
  color: var(--text);
  font-size: var(--fs-sm);
  font-family: var(--font);
  outline: none;
  transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
}
.section-filter input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--ring); }
.section-filter .search-clear-btn { margin-top: .5rem; }
.page-title { width: 100%; max-width: 900px; margin: .6rem auto .25rem; padding: 0 1rem; font-size: 1.1rem; font-weight: 700; }

.search-clear-btn {
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text-dim);
  padding: .4rem .7rem;
  font-size: var(--fs-xs);
  font-family: var(--font);
  font-weight: 500;
  border-radius: var(--r-sm);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: .3rem;
  transition: color var(--dur) var(--ease), background var(--dur) var(--ease);
}
.search-clear-btn:hover { color: var(--text); background: var(--bg-elevated); }

.md-list { width:100%; max-width:900px; margin:0 auto 1rem; padding:0 1rem; display: grid; gap: .55rem; }
.md-item {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: .85rem 1rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: .6rem;
  font-size: var(--fs-sm);
  font-weight: 500;
  transition: all var(--dur) var(--ease);
}
.md-item:hover {
  background: var(--surface);
  border-color: var(--border-hover);
  transform: translateX(4px);
}
.md-item:focus-visible { outline: none; box-shadow: 0 0 0 3px var(--ring); }
.md-item .chevron { color: var(--text-muted); font-size: var(--fs-md); }

.md-content {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 1.5rem;
  overflow: auto;
  line-height: 1.75;
  font-size: var(--fs-base);
}
.md-content pre {
  background: var(--code-bg);
  padding: .85rem 1rem;
  border-radius: var(--r-md);
  overflow: auto;
  border: 1px solid var(--border);
}
.md-content code { font-family: var(--font-mono); white-space: pre; display: block; font-size: var(--fs-sm); }
.md-content h1, .md-content h2, .md-content h3 { margin-top: 1.5em; margin-bottom: .5em; letter-spacing: -.02em; }
.md-content p { margin: .5em 0; }
.md-content a { color: var(--accent); text-decoration: none; }
.md-content a:hover { text-decoration: underline; }

/* Viewer controls */
.code-viewer { gap: 1rem; }
.viewer-top { display:flex; align-items:center; gap:.75rem; flex-wrap:wrap; }
.viewer-meta { display:flex; flex-direction:column; gap:.1rem; min-width:0; flex:1; }
.viewer-label { font-size: var(--fs-xs); font-weight: 600; letter-spacing:.2em; text-transform:uppercase; color:var(--text-muted); }
.viewer-top h2 { margin:0; font-size: var(--fs-xl); font-weight: 700; letter-spacing: -.02em; }
.muted { color:var(--text-dim); font-size:var(--fs-sm); margin:.25rem 0; }
.alert { color:var(--danger); font-size:var(--fs-sm); margin:.25rem 0; }


/* 
   CODE READER — Premium code panel
    */
.code-reader {
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  background: var(--bg-elevated);
  padding: .75rem 1rem 1rem;
  display: flex;
  flex-direction: column;
  gap: .65rem;
  transition: border-color var(--dur) var(--ease);
}
.code-reader:hover { border-color: var(--border-hover); }

.code-reader-toolbar { display:flex; align-items:center; gap:.75rem; flex-wrap:wrap; }
.code-reader-title {
  font-size: var(--fs-xs);
  letter-spacing:.12em;
  font-weight:700;
  text-transform:uppercase;
  color:var(--text-muted);
}
.code-reader-actions { display:flex; gap:.4rem; flex-wrap:wrap; margin-left:auto; }
.code-reader-actions .pill-btn.ghost { padding: .35rem .65rem; font-size: var(--fs-xs); }

.code-reader-pre {
  margin:0;
  background: var(--code-bg);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: .85rem 1rem;
  font-size: var(--fs-sm);
  overflow: auto;
  line-height: 1.65;
}
.code-reader-pre.wrap { white-space: pre-wrap; word-break: break-word; }
.code-reader-pre code { font-family: var(--font-mono); }

.code-reader-textarea {
  width:100%;
  min-height:220px;
  border-radius: var(--r-md);
  border:1px solid var(--border);
  background: var(--code-bg);
  color:var(--text);
  font-size:var(--fs-sm);
  font-family: var(--font-mono);
  padding: .85rem 1rem;
  resize:vertical;
  line-height: 1.65;
  outline: none;
  transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
}
.code-reader-textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--ring); }

.code-reader-backdrop { position:fixed; inset:0; background:rgba(0,0,0,.6); backdrop-filter:blur(8px); z-index:200; }

.code-reader.is-fullscreen {
  position:fixed;
  inset: clamp(.75rem, 3vw, 1.5rem);
  margin: 0 auto;
  max-width: min(960px, 96vw);
  height: calc(100vh - clamp(1.5rem, 6vw, 3rem));
  overflow:auto;
  z-index:210;
  padding: 1.25rem clamp(1rem, 3vw, 1.5rem);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow-lg);
  background: var(--bg-alt);
}
.code-reader.is-fullscreen .code-reader-toolbar {
  position:sticky; top:0; padding-bottom:.5rem; margin-bottom:.25rem;
  background: linear-gradient(180deg, var(--bg-alt) 60%, transparent);
  z-index:1;
}
.code-reader.is-fullscreen .code-reader-pre { max-height:calc(100vh - 180px); }
.code-reader.wrap-enabled .code-reader-pre code { white-space: pre-wrap; word-break: break-word; }
.code-reader.wrap-enabled .code-reader-textarea { white-space: pre-wrap; }


/* 
   ACCORDION — DSA Problems (Grind75 style)
    */
.accordion-root { width:100%; max-width:1000px; margin:0 auto 3rem; padding: 1rem; }

.accordion-header { display:flex; flex-direction:column; align-items:center; text-align:center; margin-bottom: .5rem; }
.accordion-header h2 { font-size: var(--fs-xl); font-weight: 700; letter-spacing: -.02em; }
.accordion-header .filter-bar { width:100%; max-width:760px; }
.accordion-sub { max-width:760px; font-size: var(--fs-sm); color: var(--text-dim); }

.accordion-topics { display:flex; flex-direction:column; gap:.7rem; }

.accordion-topic {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  overflow: hidden;
  transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
}
.accordion-topic:hover { border-color: var(--border-hover); }

.accordion-topic-toggle {
  width:100%;
  background:none;
  border:0;
  display:flex;
  align-items:center;
  gap:.65rem;
  padding: .9rem 1.1rem;
  cursor:pointer;
  text-align:left;
  font-size: var(--fs-base);
  font-weight:600;
  font-family: var(--font);
  color:var(--text);
  transition: background var(--dur) var(--ease);
  position: relative;
}
.accordion-topic-toggle:hover { background: var(--surface); }
.accordion-topic-toggle:focus-visible { outline:none; box-shadow: inset 0 0 0 2px var(--ring); }

.accordion-topic .chevron {
  transition: transform .3s var(--spring);
  font-size: var(--fs-sm);
  color: var(--text-muted);
}
.accordion-topic .chevron.open { transform: rotate(90deg); color: var(--accent); }
.topic-title { flex: 1; }

.accordion-topic .count {
  font-size: var(--fs-xs);
  font-weight: 600;
  background: var(--surface);
  padding: .2rem .5rem;
  border-radius: var(--r-sm);
  color: var(--text-dim);
  letter-spacing: .02em;
  border: 1px solid var(--border);
}

.topic-panel {
  border-top: 1px solid var(--border);
  background: var(--bg-alt);
  padding: .65rem .85rem 1rem;
}

.problem-row {
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  margin: .5rem 0 0;
  background: var(--bg-elevated);
  overflow: hidden;
  transition: border-color var(--dur) var(--ease);
}
.problem-row:first-child { margin-top: 0; }
.problem-row:hover { border-color: var(--border-hover); }

.problem-head { display:flex; }
.problem-toggle {
  flex:1;
  background:none;
  border:0;
  padding: .7rem .85rem;
  display:flex;
  align-items:center;
  gap:.6rem;
  cursor:pointer;
  text-align:left;
  color:var(--text);
  font-size: var(--fs-sm);
  font-weight: 600;
  font-family: var(--font);
  transition: background var(--dur) var(--ease);
}
.problem-toggle:hover { background: var(--surface); }
.problem-toggle:focus-visible { outline:none; box-shadow: inset 0 0 0 2px var(--ring); }

.problem-toggle .chevron {
  font-size: var(--fs-xs);
  color: var(--text-muted);
  transition: transform .3s var(--spring), color .2s;
}
.problem-toggle .chevron.open { transform: rotate(90deg); color: var(--accent); }

.problem-title { flex:1; }
.problem-meta {
  font-size: var(--fs-xs);
  font-weight: 600;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.problem-panel {
  padding: .65rem .85rem .9rem;
  display:flex;
  flex-direction:column;
  gap:.7rem;
  animation: fadeUp .3s var(--ease);
  border-top: 1px solid var(--border);
}
.problem-panel .description { font-size: var(--fs-sm); line-height:1.65; color: var(--text-dim); }
.problem-panel .description p { margin: .4em 0; }
.problem-panel pre { margin:0; background: var(--code-bg); border: 1px solid var(--border); padding: .75rem .85rem; border-radius: var(--r-md); font-size: var(--fs-xs); overflow:auto; }

.problem-tags { display:flex; flex-wrap:wrap; gap:.3rem; margin:.1rem 0 .3rem; }
.tag-chip {
  cursor:default;
  text-transform:uppercase;
  letter-spacing:.06em;
  font-size: var(--fs-xs);
  font-weight: 600;
  color: var(--accent);
  background: var(--accent-glow);
  border: 1px solid transparent;
  padding: .2rem .5rem;
  border-radius: var(--r-sm);
  border-color: var(--border);
}


/* 
   FILTER BAR & CHIPS
    */
.filter-bar {
  display:flex;
  flex-direction:column;
  gap:.6rem;
  margin:.25rem 0 1rem;
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 1rem;
}
.filter-bar input[type="search"] {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: .65rem .9rem;
  font-size: var(--fs-sm);
  font-family: var(--font);
  color: var(--text);
  outline: none;
  transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
}
.filter-bar input[type="search"]:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--ring); }

.chip-row { display:flex; flex-wrap:wrap; gap:.35rem; }

.chip {
  background: var(--surface);
  border: 1.5px solid var(--border);
  color: var(--text-dim);
  padding: .4rem .75rem;
  font-size: var(--fs-xs);
  font-family: var(--font);
  font-weight: 600;
  border-radius: var(--r-full);
  cursor: pointer;
  letter-spacing: .02em;
  transition: all var(--dur) var(--ease);
}
.chip:hover { color: var(--text); border-color: var(--border-hover); }
.chip.active {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
  box-shadow: 0 2px 12px var(--accent-glow);
}
.chip:focus-visible { outline: none; box-shadow: 0 0 0 3px var(--ring); }

.chip.clear { background: var(--danger); color:#fff; border-color: var(--danger); }
.chip.clear.big { font-size: var(--fs-xs); padding:.5rem 1rem; }
.chip.clear:hover { background:#ef4444; }

.diff-chip { position:relative; }
.diff-easy { border-color: rgba(52,211,153,.4); color: var(--success); }
.diff-medium { border-color: rgba(251,191,36,.4); color: var(--warn); }
.diff-hard { border-color: rgba(248,113,113,.4); color: var(--danger); }
.diff-chip.active.diff-easy { background: #059669; border-color: #059669; color: #fff; }
.diff-chip.active.diff-medium { background: #d97706; border-color: #d97706; color: #fff; }
.diff-chip.active.diff-hard { background: #dc2626; border-color: #dc2626; color: #fff; }

.topic-chip { border-color: var(--border); }
.topic-chip.active {
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  border-color: var(--accent);
}
.highlight-inline { background: rgba(99,102,241,.2); padding: 0 .15rem; border-radius: 3px; }
.highlight { color: var(--accent); }


/* 
   SEARCH (legacy components)
    */
.search-bar-wrapper { width:100%; padding:.6rem .9rem; position:sticky; top:var(--nav-h); z-index:15; display:flex; gap:.6rem; align-items:center; background: var(--bg-glass); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); }
.search-bar-wrapper input[type="search"] {
  flex:1;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--r-full);
  padding:.6rem .9rem;
  font-size:var(--fs-sm);
  font-family:var(--font);
  color:var(--text);
  outline:none;
  transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
}
.search-bar-wrapper input[type="search"]::placeholder { color:var(--text-muted); }
.search-bar-wrapper input[type="search"]:focus { border-color:var(--accent); box-shadow:0 0 0 3px var(--ring); }

.search-results { width:100%; max-width:760px; margin:.5rem auto 2.5rem; padding: 0 1rem; display:flex; flex-direction:column; gap:.4rem; }
.search-hit {
  background:var(--bg-elevated); border:1px solid var(--border); border-radius:var(--r-md);
  padding:.7rem .9rem; cursor:pointer; display:flex; flex-direction:column; gap:.3rem;
  transition: all var(--dur) var(--ease);
}
.search-hit:hover { background:var(--surface); border-color:var(--border-hover); }
.search-hit-title { font-size:var(--fs-sm); font-weight:600; margin:0; line-height:1.15; }
.search-hit-meta { font-size:var(--fs-xs); color:var(--text-muted); text-transform:uppercase; display:flex; gap:.75rem; letter-spacing:.04em; }
.search-hit:focus-visible { outline:none; box-shadow:0 0 0 3px var(--ring); }
.search-empty { font-size:var(--fs-xs); color:var(--text-muted); text-align:center; margin-top:2rem; }

/* Copy button */
.copy-btn { position:sticky; top:.5rem; margin-left:auto; display:inline-flex; align-items:center; gap:.35rem; padding:.35rem .6rem; font-size:var(--fs-xs); background:var(--surface); border:1px solid var(--border); color:var(--text); border-radius:var(--r-sm); cursor:pointer; }
.copy-btn:hover { background:var(--bg-elevated); }


/* 
   GAME HUB & MINI-GAMES — Premium Gamification
    */
.game-hub { width:100%; max-width:900px; margin:0 auto; padding:2rem clamp(1rem,4vw,2rem); text-align:center; }
.game-hub-title {
  font-size: var(--fs-2xl);
  font-weight: 800;
  letter-spacing: -.03em;
  margin: 0 0 .35rem;
}
.game-hub-sub { color:var(--text-dim); margin:0 0 2rem; font-size:var(--fs-md); }

.game-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:1rem; max-width: 700px; margin: 0 auto; }

.game-card {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--r-xl);
  padding: 1.75rem 1rem 1.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .6rem;
  cursor: pointer;
  text-align: center;
  transition: all var(--dur) var(--ease);
  position: relative;
  overflow: hidden;
  font-family: var(--font);
}
.game-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--accent-glow), var(--accent2-glow));
  opacity: 0;
  transition: opacity var(--dur) var(--ease);
  border-radius: inherit;
}
.game-card:hover::before { opacity: 1; }
.game-card:hover {
  transform: translateY(-4px);
  border-color: var(--accent);
  box-shadow: var(--shadow-md), 0 0 40px var(--accent-glow);
}
.game-card:active { transform: translateY(-1px) scale(.98); }

.game-card-icon { font-size: 2.4rem; position: relative; z-index: 1; transition: transform var(--dur) var(--spring); }
.game-card:hover .game-card-icon { transform: scale(1.15); }
.game-card-name { font-weight: 700; font-size: var(--fs-base); position: relative; z-index: 1; }
.game-card-desc { color: var(--text-dim); font-size: var(--fs-xs); line-height: 1.5; position: relative; z-index: 1; }

/* Shared game container */
.game-container { width:100%; max-width:760px; margin:0 auto; padding:1rem clamp(.75rem,3vw,1.5rem); }
.game-title {
  font-size: var(--fs-xl);
  font-weight: 700;
  letter-spacing: -.02em;
  margin: 0 0 .85rem;
  text-align: center;
}

.game-stats {
  display: flex;
  justify-content: center;
  gap: .65rem;
  flex-wrap: wrap;
  margin-bottom: 1.25rem;
  font-size: .82rem;
  font-weight: 600;
}
.game-stats span {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  padding: .4rem .7rem;
  border-radius: var(--r-sm);
  font-size: var(--fs-xs);
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

/* Timer */
.timer { color: var(--accent) !important; }
.timer-warn { color: var(--danger) !important; animation: pulse 1s infinite; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.4} }

/* Cards shared */
.quiz-card, .pattern-card, .recall-card, .speed-card {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--r-xl);
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: .9rem;
}

.quiz-question, .recall-front, .speed-prompt { display:flex; flex-direction:column; align-items:center; gap:.45rem; text-align:center; }
.quiz-label, .recall-label, .pattern-label, .speed-label {
  font-size: var(--fs-xs);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: .1em;
  font-weight: 600;
}
.quiz-problem-title, .recall-problem-title, .speed-problem-title { font-size: var(--fs-xl); font-weight: 700; margin: 0; letter-spacing: -.02em; }

.quiz-difficulty {
  font-size: var(--fs-xs);
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  padding: .2rem .55rem;
  border-radius: var(--r-sm);
}
.quiz-difficulty[data-diff="easy"] { color: var(--success); background: rgba(52,211,153,.1); }
.quiz-difficulty[data-diff="medium"] { color: var(--warn); background: rgba(251,191,36,.1); }
.quiz-difficulty[data-diff="hard"] { color: var(--danger); background: rgba(248,113,113,.1); }

/* Options grid */
.quiz-options { display: grid; grid-template-columns: 1fr 1fr; gap: .55rem; }
.quiz-opt {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: var(--r-md);
  padding: .75rem;
  font-size: var(--fs-sm);
  font-weight: 600;
  font-family: var(--font);
  cursor: pointer;
  text-align: center;
  color: var(--text);
  transition: all var(--dur) var(--ease);
}
.quiz-opt:hover:not(:disabled) {
  border-color: var(--accent);
  background: rgba(99,102,241,.06);
  transform: translateY(-2px);
  box-shadow: var(--shadow-sm);
}
.quiz-opt:disabled { cursor: default; opacity: .85; }
.quiz-opt.correct {
  border-color: var(--success);
  background: rgba(52,211,153,.1);
  color: var(--success);
  box-shadow: 0 0 20px rgba(52,211,153,.15);
}
.quiz-opt.wrong {
  border-color: var(--danger);
  background: rgba(248,113,113,.08);
  color: var(--danger);
}

.quiz-feedback { display:flex; flex-direction:column; align-items:center; gap:.3rem; padding:.5rem 0 0; }
.quiz-correct-msg { color: var(--success); font-weight: 700; font-size: var(--fs-base); }
.quiz-wrong-msg { color: var(--danger); font-weight: 700; font-size: var(--fs-base); }

/* Blind Recall */
.recall-tags { display:flex; flex-wrap:wrap; gap:.3rem; justify-content:center; margin-top:.3rem; }
.reveal-btn { align-self: center; font-size: var(--fs-base); padding: .7rem 2rem; }
.recall-revealed { display:flex; flex-direction:column; gap:.85rem; }
.recall-solution { max-height:400px; overflow:auto; }
.recall-rate { display:flex; flex-direction:column; align-items:center; gap:.6rem; }
.recall-rate-label { font-size: var(--fs-sm); font-weight: 600; }
.recall-rate-btns { display:flex; gap:.5rem; }
.recall-easy { background: #059669 !important; }
.recall-easy:hover { background: #047857 !important; }
.recall-medium { background: #d97706 !important; }
.recall-medium:hover { background: #b45309 !important; }
.recall-hard { background: #dc2626 !important; }
.recall-hard:hover { background: #b91c1c !important; }
.recall-hint { font-size: var(--fs-xs); color: var(--text-muted); margin: .35rem 0 .85rem; }

/* Pattern Match */
.pattern-statement { text-align:left; }
.pattern-text {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 1rem;
  margin: .6rem 0;
  font-size: var(--fs-sm);
  line-height: 1.65;
  max-height: 280px;
  overflow: auto;
  color: var(--text-dim);
}
.pattern-text p { margin: .3rem 0; }

/* Speed Round */
.speed-form { display:flex; flex-direction:column; gap:.65rem; }
.speed-input {
  width:100%;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: .85rem 1rem;
  color: var(--text);
  font-size: var(--fs-sm);
  font-family: var(--font-mono);
  resize: vertical;
  min-height: 100px;
  outline: none;
  transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
}
.speed-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--ring); }
.speed-result { display:flex; flex-direction:column; gap:.85rem; }
.speed-result-label { font-size:var(--fs-xs); text-transform:uppercase; color:var(--text-muted); letter-spacing:.1em; font-weight:600; }
.speed-yours { background:var(--surface); border:1px solid var(--border); border-radius:var(--r-md); padding:.85rem; }
.speed-user-text { font-size:var(--fs-sm); white-space:pre-wrap; margin-top:.25rem; }
.speed-self-rate { display:flex; flex-direction:column; align-items:center; gap:.55rem; font-weight:600; font-size:var(--fs-sm); }
.speed-rate-btns { display:flex; gap:.5rem; }
.speed-next { display:flex; align-items:center; justify-content:center; gap:.85rem; font-weight:600; }

/* Game Over */
.game-over { text-align:center; padding:2.5rem 1rem; }
.game-over h3 { font-size: var(--fs-2xl); font-weight: 800; letter-spacing: -.02em; margin:0 0 .5rem; }
.game-over p { color:var(--text-dim); margin:.25rem 0 1rem; }
.game-over-stats {
  display:flex;
  justify-content:center;
  gap:.85rem;
  flex-wrap:wrap;
  margin-bottom: 1.5rem;
  font-size: .85rem;
}
.game-over-stats span {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  padding: .55rem .85rem;
  border-radius: var(--r-md);
  font-size: var(--fs-sm);
  font-weight: 600;
}

/*  Legacy compat  */
.topic-list { width:100%; max-width:760px; margin:0 auto 2.75rem; padding:.25rem 0 2rem; list-style:none; }
.topic-row { display:flex; align-items:center; gap:.85rem; padding:.95rem 1rem; background:var(--bg-elevated); border:1px solid var(--border); cursor:pointer; transition:all var(--dur) var(--ease); position:relative; overflow:hidden; }
.topic-row+.topic-row { border-top:none; }
.topic-row:first-child { border-radius: var(--r-md) var(--r-md) 0 0; }
.topic-row:last-child { border-radius: 0 0 var(--r-md) var(--r-md); }
.topic-row:hover { background:var(--surface); transform:translateY(-1px); }
.topic-row h3 { margin:0; font-size:var(--fs-base); font-weight:600; flex:1; }
.topic-row small { font-size:var(--fs-xs); color:var(--text-muted); text-transform:uppercase; letter-spacing:.04em; }
.topic-row .chevron { font-size:var(--fs-sm); color:var(--text-muted); opacity:.55; }
.topic-row:focus-visible { outline:none; box-shadow:0 0 0 3px var(--ring); }

.problem-list-view { width:100%; max-width:760px; margin:0 auto 2.5rem; background:var(--bg-elevated); border:1px solid var(--border); border-radius:var(--r-md); overflow:hidden; }
.problem-list-item { display:flex; align-items:center; gap:.85rem; padding:.9rem 1rem; border-top:1px solid var(--border); cursor:pointer; transition:all var(--dur) var(--ease); }
.problem-list-item:first-child { border-top:0; }
.problem-list-item:hover { background:var(--surface); transform:translateY(-1px); }
.pli-title { flex:1; font-weight:600; font-size:var(--fs-base); }
.pli-meta { font-size:var(--fs-xs); color:var(--text-muted); }
.badge { display:inline-block; padding:.1rem .4rem; border-radius:var(--r-sm); background:var(--surface); color:var(--text); border:1px solid var(--border); font-size:var(--fs-xs); }
.problem-list-item:focus-visible { outline:none; box-shadow: inset 0 0 0 2px var(--ring); }

.separator { height:1px; background:var(--border); margin:.25rem 0 1rem; }


/* 
   RESPONSIVE — Mobile-first refinements
    */

@media (min-width: 800px) {
  header.app-header h1 { font-size: 1.05rem; }
  .problem-toggle { font-size: var(--fs-base); }
  .problem-panel .description { font-size: var(--fs-base); }
  .problem-panel pre, .code-reader-pre { font-size: var(--fs-sm); }
}

/* Tablet & below */
@media (max-width: 768px) {
  .section-grid { grid-template-columns: repeat(2, 1fr); gap: .7rem; }
  .game-grid { grid-template-columns: 1fr; max-width: 340px; margin: 0 auto; }
  main#main { padding: 1rem var(--content-pad) 3rem; }
  .home-inner { padding: 2rem 1.25rem; }
  .home-title { font-size: clamp(1.6rem, 5vw, 2.2rem); }
}

@media (max-width: 720px) {
  main#main { padding: .75rem clamp(.5rem, 4vw, 1.25rem) 2.5rem; }
  .md-container,
  .code-viewer,
  .accordion-root { padding:.65rem; border-radius:18px; }
}

@media (max-width: 700px) {
  header.app-header { padding: 0 1rem; }
  .brand-tagline { letter-spacing:.12rem; font-size:.6rem; }
  .problem-toggle { font-size: .85rem; }
  .problem-panel .description { font-size: .95rem; }
  .problem-panel pre, .code-reader-pre { font-size: .78rem; }
}

@media (max-width: 640px) {
  .md-container,
  .code-viewer,
  .accordion-root { background: transparent; border:none; box-shadow:none; }
  .code-reader { padding:.55rem .55rem .65rem; border-radius:16px; }
  .code-reader-pre { padding:.65rem .7rem; }
  .code-reader-textarea { min-height:160px; }
}

/* Phone */
@media (max-width: 600px) {
  :root { --nav-h: 56px; }

  header.app-header { gap: .5rem; }
  .brand-tagline { display: none; }
  .logo-pill { width: 34px; height: 34px; font-size: var(--fs-xs); border-radius: 10px; }
  .brand-title { font-size: var(--fs-sm); }

  header.app-header button, .pill-btn { padding: .4rem .7rem; font-size: var(--fs-xs); }
  .pill-btn.ghost { padding: .35rem .6rem; }

  .section-grid { grid-template-columns: repeat(2, 1fr); gap: .6rem; }
  .section-card { padding: 1rem .75rem; border-radius: var(--r-md); }
  .sc-icon { font-size: 1.4rem; }
  .sc-sub { font-size: var(--fs-xs); }

  .hide-sm { display: none !important; }

  .accordion-root { padding: .75rem .65rem 2.5rem; }
  .accordion-topic-toggle { padding: .75rem .8rem; }
  .problem-toggle { padding: .55rem .65rem; }
  .md-container { padding: .5rem 0; }

  .quiz-options { grid-template-columns: 1fr; }
  .game-stats { gap:.5rem; font-size:.75rem; }
  .game-stats span { padding:.25rem .45rem; }
  .recall-rate-btns, .speed-rate-btns { flex-direction: column; width: 100%; }
  .recall-rate-btns button, .speed-rate-btns button { width: 100%; }

  .game-over-stats { flex-direction: column; align-items: center; }
}

@media (max-width: 420px) {
  .section-grid { grid-template-columns: 1fr 1fr; gap: .5rem; }
  .section-card { padding: .85rem .6rem; }
  .sc-icon { font-size: 1.2rem; }

  .header-left { flex-wrap: wrap; }
  header.app-header button.icon-only { padding:.4rem; width:36px; justify-content:center; }
  header.app-header button.icon-only span.txt { display:none; }
}

@media (max-height: 640px) {
  .flash-card { height: clamp(380px, 78vh, 680px); }
}

/* Touch target minimum */
@media (hover: none) and (pointer: coarse) {
  .chip { min-height: 44px; display: inline-flex; align-items: center; }
  .quiz-opt { min-height: 48px; }
  .section-card { min-height: 72px; }
  .md-item { min-height: 48px; }
}
